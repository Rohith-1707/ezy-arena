# ==========================================
# Ezy Arena Configuration Environment File
# ==========================================

# Port configuration
PORT=5000
NODE_ENV=development

# Database connections
# Update this string if using an external PostgreSQL instance
DATABASE_URL="postgresql://postgres:ezyarenapassword@localhost:5432/ezy_arena?schema=public"

# Redis cache connection
REDIS_URL="redis://localhost:6379"

# JSON Web Token Secret (used for signing match passes and sessions)
JWT_SECRET="ezy_arena_super_secret_jwt_key_2026_change_me_in_production"

# AI Provider (gemini or mock)
AI_PROVIDER="gemini"
# Put your Gemini API Key here for actual recommendations, translations, and navigation layout processing.
# If omitted or left as mock, the platform automatically degrades gracefully to localized smart heuristics.
GEMINI_API_KEY=""

# Third-party Services (Optional for demo)
FIREBASE_CREDENTIALS_JSON=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
SENDGRID_API_KEY=""
SENDER_EMAIL="noreply@ezyarena.com"

# Google Maps API Key
# If provided, load actual maps; otherwise, fallback to standard interactive vector stadium map
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Public API URL pointing to Express backend
NEXT_PUBLIC_API_URL="http://localhost:5000"
